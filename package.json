{
  "name": "kitedesk",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "clean:next": "node scripts/clean-next.cjs",
    "dev:clean": "node scripts/clean-next.cjs && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "compile:contracts": "hardhat compile",
    "deploy:contracts": "hardhat run scripts/deploy.js --network kiteTestnet",
    "deploy:contracts:localhost": "hardhat run scripts/deploy.js --network localhost",
    "node:hardhat": "hardhat node",
    "verify:chain": "node scripts/verify-kitedesk.cjs",
    "verify:backend": "node scripts/verify-backend.cjs",
    "simulate": "npm run verify:chain && npm run verify:backend",
    "ship": "npm run lint && npm run build",
    "validate": "npm run format:check && npm run lint && npm run simulate && npm run build",
    "logo:assets": "node scripts/generate-logo-assets.cjs",
    "partners:logos": "node scripts/generate-partner-logos.cjs",
    "test:goal": "tsx scripts/test-goal-agent.ts",
    "test:goal:cjs": "tsx scripts/test-goal-agent.ts",
    "test:x402:facilitator": "node scripts/test-x402-facilitator.cjs",
    "print:agent-wallet": "node scripts/print-agent-wallet.cjs"
  },
  "dependencies": {
    "@stitches/react": "^1.2.8",
    "@supabase/supabase-js": "^2.103.0",
    "@tavily/core": "^0.7.2",
    "@vercel/speed-insights": "^2.0.0",
    "axios": "^1.15.0",
    "ethers": "^6.16.0",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^1.1.2",
    "lottie-react": "^2.4.1",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "swr": "^2.4.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.4.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "hardhat": "^2.28.4",
    "postcss": "^8",
    "prettier": "^3.8.2",
    "sharp": "^0.34.5",
    "simple-icons": "^11.15.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
