{
  "name": "kitedesk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "compile:contracts": "hardhat compile",
    "deploy:contracts": "hardhat run scripts/deploy.js --network kiteTestnet",
    "verify:chain": "node scripts/verify-kitedesk.cjs",
    "verify:backend": "node scripts/verify-backend.cjs",
    "simulate": "npm run verify:chain && npm run verify:backend",
    "validate": "npm run format:check && npm run lint && npm run simulate && npm run build",
    "logo:assets": "node scripts/generate-logo-assets.cjs"
  },
  "dependencies": {
    "@stitches/react": "^1.2.8",
    "@supabase/supabase-js": "^2.103.0",
    "axios": "^1.15.0",
    "ethers": "^6.16.0",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^1.1.2",
    "lottie-react": "^2.4.1",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "swr": "^2.4.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.4.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "hardhat": "^3.3.0",
    "postcss": "^8",
    "prettier": "^3.8.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
