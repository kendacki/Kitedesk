## 9. PAYMENT LOGIC (lib/payment.ts)

```typescript
import { ethers } from 'ethers'
import { CONTRACTS } from './constants'

// Minimal ERC-20 ABI for transfer
const ERC20_ABI = [
  'function transfer(address to, uint256 amount) returns (bool)',
  'function balanceOf(address owner) view returns (uint256)',
  'function decimals() view returns (uint8)',
  'function approve(address spender, uint256 amount) returns (bool)',
]

// The platform wallet that receives USDC (your wallet address)
const PLATFORM_WALLET = '0xYOUR_PLATFORM_WALLET_ADDRESS'

export async function payForTask(
  signer: ethers.JsonRpcSigner,
  priceUsdc: number
): Promise<string> {
  const usdcContract = new ethers.Contract(CONTRACTS.usdc, ERC20_ABI, signer)
  const decimals = await usdcContract.decimals()
  const amount = ethers.parseUnits(priceUsdc.toString(), decimals)

  const tx = await usdcContract.transfer(PLATFORM_WALLET, amount)
  const receipt = await tx.wait()

  if (!receipt || receipt.status !== 1) {
    throw new Error('Payment transaction failed')
  }

  return receipt.hash
}

export async function checkUsdcBalance(
  provider: ethers.BrowserProvider,
  address: string
): Promise<number> {
  const usdcContract = new ethers.Contract(CONTRACTS.usdc, ERC20_ABI, provider)
  const [balance, decimals] = await Promise.all([
    usdcContract.balanceOf(address),
    usdcContract.decimals(),
  ])
  return parseFloat(ethers.formatUnits(balance, decimals))
}
```

