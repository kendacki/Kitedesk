## 12. API ROUTES

### app/api/agent/route.ts
```typescript
import { NextRequest, NextResponse } from 'next/server'
import { executeAgentTask } from '@/lib/agent'
import { writeAttestation } from '@/lib/attest'
import { TaskType } from '@/types'
import { v4 as uuidv4 } from 'uuid'

export async function POST(req: NextRequest) {
  try {
    const { taskType, prompt, userAddress, paymentTxHash } = await req.json()

    if (!taskType || !prompt || !userAddress || !paymentTxHash) {
      return NextResponse.json({ error: 'Missing required fields' }, { status: 400 })
    }

    // Execute AI agent
    const output = await executeAgentTask(taskType as TaskType, prompt)

    // Write attestation to Kite chain
    const taskId = uuidv4()
    const attestationHash = await writeAttestation(taskId, userAddress, output, taskType)

    const attestationUrl = `${process.env.KITE_EXPLORER_URL}/tx/${attestationHash}`

    return NextResponse.json({
      success: true,
      taskId,
      output,
      attestationHash,
      attestationUrl,
    })
  } catch (err: any) {
    console.error('Agent execution error:', err)
    return NextResponse.json({ error: err.message }, { status: 500 })
  }
}
```

