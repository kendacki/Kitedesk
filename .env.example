# Copy to .env.local. Before deploy: npm run validate (format, lint, chain+backend sim, build)
#
# LLM (Groq — server-side agent)
GROQ_API_KEY=
# Optional override (default: openai/gpt-oss-120b)
GROQ_MODEL=openai/gpt-oss-120b

# Kite chain (use NEXT_PUBLIC_* for values read in the browser)
KITE_RPC_URL=https://rpc-testnet.gokite.ai
NEXT_PUBLIC_KITE_RPC_URL=https://rpc-testnet.gokite.ai
KITE_CHAIN_ID=2368
NEXT_PUBLIC_KITE_CHAIN_ID=2368
KITE_EXPLORER_URL=https://testnet.kitescan.ai
NEXT_PUBLIC_KITE_EXPLORER_URL=https://testnet.kitescan.ai

# Kite public relayer for gasless USDT (EIP-3009 / EIP-712). Confirm URL in https://docs.gokite.ai
KITE_RELAYER_URL=https://relayer-testnet.gokite.ai/v1/gasless/transfer
NEXT_PUBLIC_KITE_RELAYER_URL=https://relayer-testnet.gokite.ai/v1/gasless/transfer

# EIP-712 domain of the deployed USDT token (must match token.name() / version on-chain)
NEXT_PUBLIC_KITE_TOKEN_DOMAIN_NAME=PYUSD
NEXT_PUBLIC_KITE_TOKEN_DOMAIN_VERSION=1

# Testnet USDT (Test USD). KITE_* and NEXT_PUBLIC_* must match.
# Confirm the live address on https://testnet.kitescan.ai or Kite docs if the faucet changes.
KITE_USDT_CONTRACT=
NEXT_PUBLIC_KITE_USDT_CONTRACT=

# Deploy: npm run deploy:contracts — fund with testnet KITE for gas. Same key as ATTESTATION_SIGNER_PRIVATE_KEY.
DEPLOYER_PRIVATE_KEY=

# After deploy, paste the printed address (same twice).
KITE_ATTESTATION_CONTRACT=
NEXT_PUBLIC_KITE_ATTESTATION_CONTRACT=

# Server-only: signs attestTask — must be contract owner (same as deployer for default deploy).
ATTESTATION_SIGNER_PRIVATE_KEY=

# Receives USDT from users (see lib/payment.ts)
NEXT_PUBLIC_PLATFORM_WALLET=

# Supabase (payment replay + task history). Run supabase/migrations/001_kitedesk_tasks.sql in SQL editor.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
