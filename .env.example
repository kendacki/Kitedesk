# Copy to .env.local.
# Full validate: npm run validate (needs GROQ, Kite contracts, platform wallet, Supabase — see verify-backend.cjs).
# Local goal-agent smoke test: npm run test:goal:cjs (needs GROQ_API_KEY, TAVILY_API_KEY, FIRECRAWL_API_KEY).
#
# --- Critical x402 / agent wallet (do these before judging) ---
# 1) Fund ATTESTATION_SIGNER_PRIVATE_KEY with testnet KITE (gas) + USDT on KITE_X402_TOKEN (x402 tool calls fail without USDT).
#    Print address: npm run print:agent-wallet — then faucet https://faucet.gokite.ai + USDT per Kite docs (keep ~1+ USDT for demos).
# 2) Vercel: set INTERNAL_API_BASE_URL=https://<your-deployment>.vercel.app (no trailing slash). Without it, goal mode may call 127.0.0.1.
#    Also set NEXT_PUBLIC_APP_URL to the same production URL so 402 resource URLs in API responses are correct.
# 3) After attestation contract changes: npm run deploy:contracts and set KITE_ATTESTATION_CONTRACT (+ NEXT_PUBLIC_*).
# 4) Before deploy: npm run build (fix all TypeScript errors).
#
# x402 / USDT balance: browser reads NEXT_PUBLIC_*; omitting USDT vars falls back to this testnet USDT.
KITE_X402_TOKEN=0x0fF5393387ad2f9f691FD6Fd28e07E3969e27e63
NEXT_PUBLIC_KITE_X402_TOKEN=0x0fF5393387ad2f9f691FD6Fd28e07E3969e27e63
KITE_FACILITATOR_URL=https://facilitator.pieverse.io
# Optional: official Kite x402 demo resource (documentation / future tools)
KITE_X402_DEMO_API=https://x402.dev.gokite.ai/api/weather
#
# LLM (Groq — server-side agent)
GROQ_API_KEY=

# Goal agent tools (Tavily search + Firecrawl scrape)
TAVILY_API_KEY=
FIRECRAWL_API_KEY=

# Production URL for server-side goal agent → /api/x402/* (required on Vercel; NOT localhost)
INTERNAL_API_BASE_URL=
# Same canonical site URL (browser + 402 resource field); match INTERNAL_API_BASE_URL on Vercel
NEXT_PUBLIC_APP_URL=
# Optional override (default: openai/gpt-oss-120b)
GROQ_MODEL=openai/gpt-oss-120b

# Kite chain (use NEXT_PUBLIC_* for values read in the browser)
KITE_RPC_URL=https://rpc-testnet.gokite.ai
NEXT_PUBLIC_KITE_RPC_URL=https://rpc-testnet.gokite.ai
KITE_CHAIN_ID=2368
NEXT_PUBLIC_KITE_CHAIN_ID=2368
KITE_EXPLORER_URL=https://testnet.kitescan.ai
NEXT_PUBLIC_KITE_EXPLORER_URL=https://testnet.kitescan.ai

# Kite public gasless relayer (optional). The hostname relayer-testnet.gokite.ai often does not resolve;
# the app uses a standard ERC-20 transfer from the user wallet (user pays KITE gas). Uncomment when Kite publishes a working URL.
# KITE_RELAYER_URL=
# NEXT_PUBLIC_KITE_RELAYER_URL=

# EIP-712 domain of the deployed USDT token (must match token.name() / version on-chain)
NEXT_PUBLIC_KITE_TOKEN_DOMAIN_NAME=PYUSD
NEXT_PUBLIC_KITE_TOKEN_DOMAIN_VERSION=1

# Testnet USDT / PYUSD (EIP-712 domain name/version below are fallbacks for x402 agent signing).
# If unset, the app uses the Kite testnet USDT default (same address as KITE_X402_TOKEN above).
# Confirm the live address on https://testnet.kitescan.ai or Kite docs if the faucet changes.
KITE_USDT_CONTRACT=
NEXT_PUBLIC_KITE_USDT_CONTRACT=

# Deploy: npm run deploy:contracts — fund with testnet KITE for gas. Same key as ATTESTATION_SIGNER_PRIVATE_KEY.
DEPLOYER_PRIVATE_KEY=

# After deploy, paste the printed address (same twice).
KITE_ATTESTATION_CONTRACT=
NEXT_PUBLIC_KITE_ATTESTATION_CONTRACT=

# Server-only: signs attestTask — must be contract owner (same as deployer for default deploy).
ATTESTATION_SIGNER_PRIVATE_KEY=

# Receives USDT from users (see lib/payment.ts)
NEXT_PUBLIC_PLATFORM_WALLET=

# Supabase (payment replay + task history). Run supabase/migrations/001_kitedesk_tasks.sql in SQL editor.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
